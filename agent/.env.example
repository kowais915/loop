# LOOP agent — environment. Copy to `.env` and fill in. Never commit `.env`.

# --- Splunk MCP Server (real data source) ---------------------------------
# Streamable-HTTP MCP endpoint, e.g. https://your-splunk-host:8089/services/mcp/
SPLUNK_MCP_URL=
SPLUNK_MCP_TOKEN=

# --- Splunk Hosted Models (Foundation-Sec-8B, OpenAI-compatible) ----------
HOSTED_MODEL_URL=
HOSTED_MODEL_KEY=
HOSTED_MODEL_NAME=foundation-sec-8b

# --- Orchestrator fallback (only used if hosted model is unreachable) ------
ANTHROPIC_API_KEY=

# --- Supabase (Postgres + realtime + pgvector) ----------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- App config -----------------------------------------------------------
# Comma-separated origins allowed by CORS (the Vercel domain + localhost).
LOOP_CORS_ORIGINS=http://localhost:3000
# Set to 1 to allow the loop to run with stubbed Splunk/model when creds are
# absent (useful for local UI dev). 0 = require live creds.
LOOP_ALLOW_STUBS=1
