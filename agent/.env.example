# LOOP agent — environment. Copy to `.env` and fill in. Never commit `.env`.
# Run the agent on port 8001 locally (Splunk's web UI owns 8000):
#   uvicorn main:app --port 8001

# --- Splunk MCP Server (real data source) ---------------------------------
# Streamable-HTTP MCP endpoint. Copy this from the Splunk MCP Server app's
# connection panel. Local Enterprise: https://localhost:8089/services/mcp
SPLUNK_MCP_URL=
# Encrypted token generated INSIDE the Splunk MCP Server app (shown once).
SPLUNK_MCP_TOKEN=
# Local Splunk uses a self-signed cert on 8089 — set 0 for localhost, 1 for Cloud.
SPLUNK_VERIFY_TLS=1

# --- Seed loader only (agent/seed/load_seed.py) ---------------------------
# HEC endpoint + token used to load demo data into index=ecommerce.
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# --- Splunk Hosted Models (Foundation-Sec-8B, OpenAI-compatible) ----------
HOSTED_MODEL_URL=
HOSTED_MODEL_KEY=
HOSTED_MODEL_NAME=foundation-sec-8b

# --- Orchestrator fallback (only used if hosted model is unreachable) ------
ANTHROPIC_API_KEY=

# --- Supabase (Postgres + realtime + pgvector) ----------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- App config -----------------------------------------------------------
# Comma-separated origins allowed by CORS (the Vercel domain + localhost).
LOOP_CORS_ORIGINS=http://localhost:3000
# Set to 1 to allow the loop to run with stubbed Splunk/model when creds are
# absent (useful for local UI dev). 0 = require live creds.
LOOP_ALLOW_STUBS=1
